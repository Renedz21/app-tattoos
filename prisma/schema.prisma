generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  // Relaciones inversas (no cambian Better Auth, solo ayudan a Prisma)
  tattooRequests         TattooRequest[] @relation("UserRequests")
  assignedTattooRequests TattooRequest[] @relation("AssignedRequests")
  verifiedPayments       Payment[]       @relation("VerifiedPayments")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum TattooStyle {
  FINE_LINE
  BLACKWORK
  REALISM
  TRADITIONAL
  LETTERING
  MINIMAL
  OTHER
}

enum TattooSize {
  SMALL
  MEDIUM
  LARGE
  OTHER
}

enum ColorMode {
  BLACK_AND_GREY
  COLOR
}

enum RequestStatus {
  // Antes de enviar lead
  DRAFT
  REFERENCES_SET
  GENERATED

  // Admin pipeline
  SENT
  QUOTED
  DEPOSIT_PENDING
  APPOINTMENT_CONFIRMED
  FINISHED
  EXPIRED
}

enum ImageKind {
  INITIAL
  VARIATION
  REFINEMENT
}

enum JobType {
  GENERATE_IMAGES
  GENERATE_VARIATIONS
  REFINE_IMAGE
}

enum JobStatus {
  QUEUED
  PROCESSING
  DONE
  ERROR
  CANCELLED
}

enum AiProvider {
  AI_STUDIO
  VERTEX
}

enum PaymentKind {
  DEPOSIT
  FULL
}

enum PaymentMethod {
  YAPE
  PLIN
  TRANSFER
  CASH
  OTHER
}

enum PaymentStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  REJECTED
  EXPIRED
  CANCELLED
}

model TattooRequest {
  id String @id @default(cuid())

  // Visible ID tipo ZT-001 (se setea cuando se envía)
  requestCode String? @unique

  // Token público para tracking: /t/<trackingToken>
  trackingToken String @unique @default(cuid())

  status RequestStatus @default(DRAFT)

  // Usuario opcional (login opcional)
  userId String?
  user   User?   @relation("UserRequests", fields: [userId], references: [id], onDelete: SetNull)

  // Asignación a admin/staff (opcional)
  assignedToId String?
  assignedTo   User?   @relation("AssignedRequests", fields: [assignedToId], references: [id], onDelete: SetNull)

  // Step 1
  title       String?
  style       TattooStyle @default(OTHER)
  styleOther  String?
  bodyZone    String
  size        TattooSize  @default(OTHER)
  sizeNotes   String?
  colorMode   ColorMode   @default(BLACK_AND_GREY)
  detailLevel Int         @default(3)

  // Step 2
  specialInstructions String?
  finalPrompt         String?

  // Step 3: imagen favorita
  selectedImageId String?
  selectedImage   GeneratedImage? @relation("SelectedImage", fields: [selectedImageId], references: [id], onDelete: SetNull)

  // Step final (cotización enviada)
  fullName      String?
  whatsappE164  String?
  district      String?
  availability  String?
  extraComments String?

  // Cotización admin
  currency     String    @default("PEN")
  priceCents   Int?
  depositCents Int?
  depositDueAt DateTime?

  // Timeline simple (sin tabla de eventos)
  sentAt             DateTime?
  quotedAt           DateTime?
  depositSubmittedAt DateTime?
  depositConfirmedAt DateTime?
  appointmentAt      DateTime?
  finishedAt         DateTime?
  expiredAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referenceImages ReferenceImage[] @relation("RequestRefImages")
  generatedImages GeneratedImage[] @relation("RequestImages")
  jobs            GenerationJob[]  @relation("RequestJobs")
  payments        Payment[]        @relation("RequestPayments")

  @@index([status, createdAt])
  @@index([requestCode])
  @@index([fullName])
  @@index([whatsappE164])
  @@map("tattoo_request")
}

model ReferenceImage {
  id String @id @default(cuid())

  requestId String
  request   TattooRequest @relation("RequestRefImages", fields: [requestId], references: [id], onDelete: Cascade)

  // R2
  r2Key     String
  publicUrl String?
  mimeType  String?
  sizeBytes Int?

  createdAt DateTime @default(now())

  @@unique([requestId, r2Key])
  @@index([requestId, createdAt])
  @@map("reference_image")
}

model GeneratedImage {
  id String @id @default(cuid())

  requestId String
  request   TattooRequest @relation("RequestImages", fields: [requestId], references: [id], onDelete: Cascade)

  // Back relation para selectedImage (Prisma lo exige)
  selectedIn TattooRequest[] @relation("SelectedImage")

  kind      ImageKind @default(INITIAL)
  slotIndex Int?

  // R2
  r2Key     String
  publicUrl String?
  mimeType  String? @default("image/png")
  sizeBytes Int?

  modelName String?
  seed      String?

  // Variaciones/refine
  parentImageId String?
  parentImage   GeneratedImage?  @relation("ImageParent", fields: [parentImageId], references: [id], onDelete: SetNull)
  children      GeneratedImage[] @relation("ImageParent")

  // Back relation para GenerationJob.baseImage
  baseForJobs GenerationJob[] @relation("JobBaseImage")

  createdAt DateTime @default(now())

  @@unique([requestId, kind, slotIndex])
  @@index([requestId, createdAt])
  @@map("generated_image")
}

model GenerationJob {
  id String @id @default(cuid())

  requestId String
  request   TattooRequest @relation("RequestJobs", fields: [requestId], references: [id], onDelete: Cascade)

  type   JobType
  status JobStatus @default(QUEUED)

  baseImageId String?
  baseImage   GeneratedImage? @relation("JobBaseImage", fields: [baseImageId], references: [id], onDelete: SetNull)

  provider  AiProvider @default(AI_STUDIO)
  modelName String

  attempts    Int @default(0)
  maxAttempts Int @default(3)

  runAt    DateTime  @default(now())
  lockedAt DateTime?
  lockedBy String?
  error    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, runAt])
  @@index([requestId, createdAt])
  @@map("generation_job")
}

model Payment {
  id String @id @default(cuid())

  requestId String
  request   TattooRequest @relation("RequestPayments", fields: [requestId], references: [id], onDelete: Cascade)

  kind   PaymentKind    @default(DEPOSIT)
  status PaymentStatus  @default(PENDING)
  method PaymentMethod?

  currency    String @default("PEN")
  amountCents Int

  dueAt  DateTime?
  paidAt DateTime?

  // Comprobante (manual) en el MVP
  proofR2Key     String?
  proofUrl       String?
  proofMimeType  String?
  proofSizeBytes Int?

  verifiedById String?
  verifiedBy   User?     @relation("VerifiedPayments", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedAt   DateTime?
  adminNote    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestId, createdAt])
  @@index([status, dueAt])
  @@map("payment")
}

model PortfolioItem {
  id String @id @default(cuid())

  title       String
  description String?
  style       TattooStyle @default(OTHER)
  bodyZone    String?
  colorMode   ColorMode   @default(BLACK_AND_GREY)

  isPublished Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images PortfolioImage[]

  @@index([isPublished, sortOrder])
  @@index([style])
  @@map("portfolio_item")
}

model PortfolioImage {
  id String @id @default(cuid())

  itemId String
  item   PortfolioItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  // R2
  r2Key     String
  publicUrl String?
  mimeType  String?
  sizeBytes Int?

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([itemId, r2Key])
  @@index([itemId, sortOrder])
  @@map("portfolio_image")
}
